<?xml version="1.0"?>
<ruleset name="Ambrosia Dosage Calculator">
	<description>WordPress coding standards for the Ambrosia Dosage Calculator plugin.</description>

	<arg name="basepath" value="."/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>
	<arg value="ps"/>

	<!-- Scan these paths -->
	<file>.</file>

	<!-- Exclude non-project directories -->
	<exclude-pattern>/vendor/*</exclude-pattern>
	<exclude-pattern>/node_modules/*</exclude-pattern>
	<exclude-pattern>/.specify/*</exclude-pattern>
	<exclude-pattern>/.claude/*</exclude-pattern>
	<exclude-pattern>/.pi/*</exclude-pattern>
	<exclude-pattern>/.circleci/*</exclude-pattern>
	<exclude-pattern>*.min.js</exclude-pattern>
	<exclude-pattern>*.min.css</exclude-pattern>
	<exclude-pattern>/build/*</exclude-pattern>
	<exclude-pattern>/bin/*</exclude-pattern>

	<!-- WordPress standards -->
	<rule ref="WordPress"/>

	<!-- Short ternaries (?:) are intentionally used throughout; WP ban is project-specific -->
	<rule ref="Universal.Operators.DisallowShortTernary">
		<exclude name="Universal.Operators.DisallowShortTernary.Found"/>
	</rule>

	<!-- Direct DB queries are intentional and reviewed — all use $wpdb->prepare() -->
	<rule ref="WordPress.DB.DirectDatabaseQuery">
		<exclude name="WordPress.DB.DirectDatabaseQuery.DirectQuery"/>
		<exclude name="WordPress.DB.DirectDatabaseQuery.NoCaching"/>
	</rule>

	<!-- Table names are trusted (ADC_DB::table() returns prefixed table names, not user input) -->
	<rule ref="WordPress.DB.PreparedSQL">
		<exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
		<exclude name="WordPress.DB.PreparedSQL.NotPrepared"/>
	</rule>

	<!-- error_log() is intentional for debug logging -->
	<rule ref="WordPress.PHP.DevelopmentFunctions">
		<exclude name="WordPress.PHP.DevelopmentFunctions.error_log_error_log"/>
	</rule>

	<!--
	  File system operations: fopen/fclose/fwrite are used for:
	  - CSV export (php://memory stream, then stream_get_contents)
	  - CSV import (reading uploaded tmp_name file)
	  WP_Filesystem does not apply to in-memory streams or server-side temp files.
	  file_get_contents is used only for local uploaded tmp_name files, not remote URLs.
	-->
	<rule ref="WordPress.WP.AlternativeFunctions">
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_fopen"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_fclose"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_system_operations_fwrite"/>
		<exclude name="WordPress.WP.AlternativeFunctions.file_get_contents_file_get_contents"/>
	</rule>

	<!-- Inline comments don't require terminal punctuation in this codebase -->
	<rule ref="Squiz.Commenting.InlineComment">
		<exclude name="Squiz.Commenting.InlineComment.InvalidEndChar"/>
	</rule>

	<!-- PHP version target: 8.0–8.3. Suppress false positives for modern operators. -->
	<config name="testVersion" value="8.0-8.3"/>

	<!-- Text domain as declared in plugin header -->
	<config name="text_domain" value="ambrosia-dosage-calc"/>

	<!-- WordPress minimum version -->
	<config name="minimum_supported_wp_version" value="6.0"/>
</ruleset>
